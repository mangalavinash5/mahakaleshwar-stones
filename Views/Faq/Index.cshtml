@model List<JaipurMeniral.Models.Faq>
@{
    ViewData["Title"] = "FAQ - Sandstone Export Questions | Mahakaleshwar Stones";
    ViewData["MetaDescription"] = "Frequently asked questions about ordering natural stone from India — export, finishes, delivery, MOQ, packaging, and more.";
    var categories = Model.Select(f => f.Category).Distinct().ToList();
}

<!-- Page Hero -->
<section class="page-hero page-hero-sm"
         style="background-image: url('https://images.unsplash.com/photo-1565182999561-18d7dc61c393?w=1920&q=80')">
    <div class="page-hero-overlay"></div>
    <div class="container text-center text-white position-relative">
        <h1 class="page-hero-title">Frequently Asked <span class="text-gold">Questions</span></h1>
        <p class="page-hero-subtitle">Everything you need to know about natural stone export from India</p>
        <nav aria-label="breadcrumb" class="d-flex justify-content-center">
            <ol class="breadcrumb breadcrumb-light">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item active">FAQ</li>
            </ol>
        </nav>
    </div>
</section>

<section class="section-padding">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-3 mb-4 mb-lg-0">
                <div class="faq-sidebar sticky-sidebar">
                    <h6 class="fw-bold mb-3 text-uppercase letter-spacing">Categories</h6>
                    <div class="faq-cat-nav">
                        <button class="faq-cat-btn active" data-cat="all">All Questions <span
                            class="badge">@Model.Count</span></button>
                            @foreach (var cat in categories)
                            {
                                <button class="faq-cat-btn" data-cat="@cat">@cat <span class="badge">@Model.Count(f =>
                                                                    f.Category == cat)</span></button>
                                }
                            </div>
                            <div class="mt-4 p-3 bg-light-stone rounded-3">
                                <h6 class="fw-bold mb-2">Still have questions?</h6>
                                <p class="text-muted small mb-3">Can't find your answer? Our team is ready to help.</p>
                                <a asp-controller="Contact" asp-action="Index" class="btn btn-gold w-100 btn-sm mb-2">Contact
                                    Us</a>
                                    <a href="https://wa.me/919999999999" target="_blank" class="btn btn-whatsapp w-100 btn-sm">
                                        <i class="fab fa-whatsapp me-1"></i>WhatsApp
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- FAQ Accordion -->
                        <div class="col-lg-9">
                            <div class="accordion accordion-stone" id="faqAccordion">
                                @foreach (var faq in Model)
                                {
                                    <div class="accordion-item faq-item" data-category="@faq.Category">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                                    data-bs-target="#faq@(faq.Id)">
                                                <span class="faq-q-icon"><i class="fas fa-question-circle"></i></span>
                                                @faq.Question
                                            </button>
                                        </h2>
                                        <div id="faq@(faq.Id)" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                <i class="fas fa-check-circle text-gold me-2"></i>@faq.Answer
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </section>

