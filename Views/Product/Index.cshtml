@model JaipurMeniral.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = "Products - Natural Stone Tiles, Slabs & More | Mahakaleshwar Stones";
}

<!-- Page Hero -->
<section class="page-hero page-hero-sm"
         style="background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1920&q=80')">
    <div class="page-hero-overlay"></div>
    <div class="container text-center text-white position-relative">
        <h1 class="page-hero-title">Our <span class="text-gold">Products</span></h1>
        <p class="page-hero-subtitle">Premium Natural Stone — Sourced, Processed & Exported from Rajasthan</p>
        <nav aria-label="breadcrumb" class="d-flex justify-content-center">
            <ol class="breadcrumb breadcrumb-light">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item active">Products</li>
            </ol>
        </nav>
    </div>
</section>

<!-- Search & Filter Bar -->
<div class="filter-bar bg-white shadow-sm sticky-top-sub">
    <div class="container py-3">
        <form method="get" asp-controller="Product" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-lg-4 col-md-5">
                <div class="search-input-wrap">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" class="form-control ps-5" name="search" value="@Model.SearchTerm"
                           placeholder="Search products..." />
                </div>
            </div>
            <div class="col-lg-3 col-md-4">
                <select class="form-select" name="category">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Slug" selected="@(Model.SelectedCategory == cat.Slug ? "selected" : null)">
                            @cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-lg-2 col-md-3">
                    <button type="submit" class="btn btn-gold w-100"><i class="fas fa-filter me-1"></i>Filter</button>
                </div>
                <div class="col-lg-3 col-md-12 text-end">
                    <span class="text-muted">Showing <strong>@Model.Products.Count</strong> of
                        <strong>@Model.TotalCount</strong> products</span>
                    </div>
                </form>
            </div>
        </div>

        <!-- Products Grid -->
        <section class="section-padding">
            <div class="container">
                <!-- Active Filters -->
                @if (!string.IsNullOrEmpty(Model.SelectedCategory) || !string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <div class="active-filters mb-4">
                        @if (!string.IsNullOrEmpty(Model.SelectedCategory))
                        {
                            <span class="filter-tag">
                                Category: @Model.Categories.FirstOrDefault(c => c.Slug == Model.SelectedCategory)?.Name
                                <a asp-controller="Product" asp-action="Index" asp-route-search="@Model.SearchTerm"><i
                                    class="fas fa-times ms-1"></i></a>
                                </span>
                            }
                            @if (!string.IsNullOrEmpty(Model.SearchTerm))
                            {
                                <span class="filter-tag">
                                    Search: "@Model.SearchTerm"
                                    <a asp-controller="Product" asp-action="Index" asp-route-category="@Model.SelectedCategory"><i
                                        class="fas fa-times ms-1"></i></a>
                                    </span>
                                }
                                <a asp-controller="Product" asp-action="Index" class="btn btn-sm btn-link text-muted">Clear All</a>
                            </div>
                        }

                        @if (!Model.Products.Any())
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-search fa-3x text-muted mb-3"></i>
                                <h4>No products found</h4>
                                <p class="text-muted">Try adjusting your search or filter criteria.</p>
                                <a asp-controller="Product" asp-action="Index" class="btn btn-gold mt-2">View All Products</a>
                            </div>
                        }
                        else
                        {
                            <div class="row g-4">
                                @foreach (var product in Model.Products)
                                {
                                    <div class="col-lg-3 col-md-4 col-sm-6">
                                        <div class="product-card">
                                            <div class="product-img-wrap">
                                                <img src="@product.Images.FirstOrDefault()" alt="@product.Name" loading="lazy" />
                                                <div class="product-overlay">
                                                    <div class="product-actions">
                                                        <a asp-controller="Product" asp-action="Details" asp-route-slug="@product.Slug"
                                                           class="btn btn-sm btn-light rounded-pill px-3">View Details</a>
                                                        <button class="btn btn-sm btn-gold rounded-pill px-3"
                                                                onclick="openInquiry('@product.Name')">Enquire</button>
                                                    </div>
                                                </div>
                                                <div class="product-badge">@product.CategoryName</div>
                                            </div>
                                            <div class="product-body">
                                                <h6 class="product-name">
                                                    <a asp-controller="Product" asp-action="Details"
                                                       asp-route-slug="@product.Slug">@product.Name</a>
                                                </h6>
                                                <div class="product-meta">
                                                    <span><i class="fas fa-palette me-1 text-gold"></i>@product.FinishType</span>
                                                    <span><i class="fas fa-ruler me-1 text-gold"></i>@product.Size</span>
                                                </div>
                                                <p class="product-desc text-muted small">@product.ShortDescription</p>
                                                <div class="product-footer">
                                                    <button class="btn btn-sm btn-gold w-100" onclick="openInquiry('@product.Name')">
                                                        <i class="fas fa-paper-plane me-1"></i>Inquiry Now
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Pagination -->
                            @if (Model.TotalPages > 1)
                            {
                                <nav class="mt-5 d-flex justify-content-center" aria-label="Product pages">
                                    <ul class="pagination pagination-stone">
                                        @if (Model.CurrentPage > 1)
                                        {
                                            <li class="page-item">
                                                <a class="page-link" asp-controller="Product" asp-action="Index"
                                                       asp-route-page="@(Model.CurrentPage - 1)" asp-route-category="@Model.SelectedCategory"
                                                       asp-route-search="@Model.SearchTerm">
                                                    <i class="fas fa-chevron-left"></i>
                                                </a>
                                            </li>
                                        }
                                        @for (int p = 1; p <= Model.TotalPages; p++)
                                        {
                                            <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                                                <a class="page-link" asp-controller="Product" asp-action="Index" asp-route-page="@p"
                                                   asp-route-category="@Model.SelectedCategory" asp-route-search="@Model.SearchTerm">@p</a>
                                            </li>
                                        }
                                        @if (Model.CurrentPage < Model.TotalPages)
                                        {
                                            <li class="page-item">
                                                <a class="page-link" asp-controller="Product" asp-action="Index"
                                                       asp-route-page="@(Model.CurrentPage + 1)" asp-route-category="@Model.SelectedCategory"
                                                       asp-route-search="@Model.SearchTerm">
                                                    <i class="fas fa-chevron-right"></i>
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </nav>
                            }
                        }
                    </div>
                </section>
