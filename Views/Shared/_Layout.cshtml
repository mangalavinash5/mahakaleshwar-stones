<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#1a1a1a" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>@ViewData["Title"]</title>
    <meta name="description"
          content="@(ViewData["MetaDescription"] ?? "Mahakaleshwar Stones - Premium Sandstone Manufacturer & Exporter from Rajasthan, India. Quality natural stone tiles, slabs, cladding, and more for worldwide export.")" />
    <meta name="keywords"
          content="@(ViewData["MetaKeywords"] ?? "sandstone tiles, sandstone slabs, wall cladding, natural stone exporter, India, Rajasthan, Jaipur")" />
    <meta property="og:title" content="@ViewData["Title"]" />
    <meta property="og:description"
          content="@(ViewData["MetaDescription"] ?? "Premium Sandstone Manufacturer & Exporter from Rajasthan, India")" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1200&q=80" />
    <link rel="canonical" href="https://www.jaipurmeniral.com@(Context.Request.Path)" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Structured Schema -->
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "Organization",
          "name": "Mahakaleshwar Stones",
          "url": "https://www.jaipurmeniral.com",
          "description": "Premium Sandstone Manufacturer & Exporter from Rajasthan, India",
          "address": {
            "@@type": "PostalAddress",
            "addressLocality": "Jaipur",
            "addressRegion": "Rajasthan",
            "addressCountry": "IN"
          },
          "contactPoint": {
            "@@type": "ContactPoint",
            "telephone": "+91-99999-99999",
            "contactType": "sales"
          }
        }
    </script>
</head>

<body>
    <!-- Preloader -->
    <div id="preloader">
        <div class="preloader-inner">
            <div class="spinner-ring"></div>
            <p>Mahakaleshwar Stones</p>
        </div>
    </div>

    <!-- Navbar -->
    @await Html.PartialAsync("_Navbar")

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    @await Html.PartialAsync("_Footer")

    <!-- WhatsApp Floating Button -->
    @await Html.PartialAsync("_WhatsAppButton")

    <!-- Back to Top -->
    <button id="backToTop" class="back-to-top" title="Back to top">
        <i class="fas fa-chevron-up"></i>
    </button>

    <!-- Inquiry Modal -->
    <div class="modal fade" id="inquiryModal" tabindex="-1" aria-labelledby="inquiryModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content inquiry-modal-content">
                <div class="modal-header inquiry-modal-header">
                    <div>
                        <h4 class="modal-title" id="inquiryModalLabel"><i class="fas fa-paper-plane me-2"></i>Send
                            Inquiry</h4>
                            <p class="mb-0 opacity-75 small">We'll respond within 24 hours</p>
                        </div>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <form id="inquiryForm">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Full Name <span
                                        class="text-danger">*</span></label>
                                        <input type="text" class="form-control form-control-lg" name="Name"
                                               placeholder="Your Name" required />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold">Email Address <span
                                            class="text-danger">*</span></label>
                                            <input type="email" class="form-control form-control-lg" name="Email"
                                                   placeholder="your@email.com" required />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-semibold">Phone / WhatsApp <span
                                                class="text-danger">*</span></label>
                                                <input type="tel" class="form-control form-control-lg" name="Phone"
                                                       placeholder="+1 234 567 8900" required />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Country <span class="text-danger">*</span></label>
                                                <select class="form-select form-select-lg" name="Country" required>
                                                    <option value="">Select Country</option>
                                                    <option>United Kingdom</option>
                                                    <option>United States</option>
                                                    <option>Australia</option>
                                                    <option>UAE</option>
                                                    <option>Singapore</option>
                                                    <option>Germany</option>
                                                    <option>France</option>
                                                    <option>Netherlands</option>
                                                    <option>Canada</option>
                                                    <option>New Zealand</option>
                                                    <option>Saudi Arabia</option>
                                                    <option>Qatar</option>
                                                    <option>South Africa</option>
                                                    <option>Other</option>
                                                </select>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label fw-semibold">Product of Interest</label>
                                                <input type="text" class="form-control form-control-lg" name="ProductName"
                                                       id="modalProductName" placeholder="e.g. Jodhpur Pink Sandstone Tiles" />
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label fw-semibold">Your Message / Requirements <span
                                                    class="text-danger">*</span></label>
                                                    <textarea class="form-control" name="Message" rows="4"
                                                              placeholder="Tell us about your project, quantity required, sizes needed..."
                                                              required></textarea>
                                                </div>
                                            </div>
                                            <div class="mt-4 d-flex gap-2 align-items-stretch flex-wrap">
                                                <button type="submit" class="btn btn-gold btn-lg flex-fill flex-sm-grow-0 px-4"
                                                        id="inquirySubmitBtn" style="min-width:160px">
                                                    <span class="submit-text"><i class="fas fa-paper-plane me-2"></i>Send Inquiry</span>
                                                    <span class="submit-loading d-none"><span
                                                        class="spinner-border spinner-border-sm me-2"></span>Sending...</span>
                                                    </button>
                                                    <a href="https://wa.me/919999999999" target="_blank"
                                                           class="btn btn-whatsapp-outline btn-lg flex-fill flex-sm-grow-0 px-4"
                                                           style="min-width:160px">
                                                        <i class="fab fa-whatsapp me-2"></i>WhatsApp
                                                    </a>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Success Toast -->
                            <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
                                <div id="successToast" class="toast align-items-center text-white bg-success border-0" role="alert">
                                    <div class="d-flex">
                                        <div class="toast-body fs-6">
                                            <i class="fas fa-check-circle me-2"></i><span id="toastMessage">Inquiry sent successfully!</span>
                                        </div>
                                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                                    </div>
                                </div>
                            </div>

                            <!-- Scripts -->
                            <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
                            <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
                            <script src="~/js/site.js" asp-append-version="true"></script>
                            @await RenderSectionAsync("Scripts", required: false)
                        </body>

                    </html>
